# Copie para .env (cp env.example .env) e preencha os três valores.

# Chave da API do gateway — gere uma forte: openssl rand -hex 24
EVOLUTION_APIKEY=TROQUE-POR-UMA-CHAVE-FORTE

# Senha do Postgres interno (só é usada dentro do docker): openssl rand -hex 16
POSTGRES_PASSWORD=TROQUE-POR-UMA-SENHA

# Domínio do gateway. Sem DNS próprio, use sslip.io com o IP do VPS
# trocando pontos por traços: IP 203.0.113.10 -> 203-0-113-10.sslip.io
DOMAIN=SEU-IP-COM-TRACOS.sslip.io
