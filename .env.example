# Conexao com o Postgres (Neon, Supabase, Vercel Postgres, etc)
# DATABASE_URL = URL com pooler (PgBouncer). Ex Neon: host com "-pooler"
# DIRECT_URL   = URL sem pooler, necessario para prisma migrate (advisory lock)
# Em Neon, basta remover "-pooler" do hostname pra obter a URL direta.
DATABASE_URL="postgresql://user:password@host-pooler/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# URL publica do site (SEO: metadataBase, sitemap, Open Graph). Obrigatorio em producao com dominio proprio.
# Ex.: https://investimentosdeaz.com.br (sem barra final)
NEXT_PUBLIC_SITE_URL=""

# Segredo usado para assinar cookies de sessao
# Gere um valor aleatorio (>= 32 caracteres). Ex.: openssl rand -hex 32
AUTH_SECRET="troque-isto-em-producao-com-um-valor-aleatorio-longo"

# Editor opcional criado pelo seed (npm run db:seed-admin)
# Em producao voce cria editores pela tela /area-restrita/usuarios
ADMIN_EMAIL="editor@example.com"
ADMIN_PASSWORD="trocar-em-producao"

# YouTube Data API v3 (alimenta /videos)
# Como obter a chave:
#   1. https://console.cloud.google.com -> novo projeto
#   2. APIs & Services -> Library -> "YouTube Data API v3" -> Enable
#   3. APIs & Services -> Credentials -> Create credentials -> API key
#   4. Cole o valor (formato AIzaSy...) abaixo
YOUTUBE_API_KEY=""
# Channel ID do canal alvo (formato UC...)
YOUTUBE_CHANNEL_ID="UCuMfW1AOhcbSP1zRG5hyBZQ"

# Vercel Blob — URL publica do store (sem barra final). Usada pelo painel economico para
# carregar JSONs em /data/* e SVGs em /charts/static/* gerados pelo data-pipeline.
# Ex.: https://xxxxxxxx.public.blob.vercel-storage.com
NEXT_PUBLIC_BLOB_BASE_URL=""

# Opcional: mesma URL do store Blob, so no servidor (SSR) se o build nao tiver enxertado NEXT_PUBLIC.
# Cliente ainda precisa de NEXT_PUBLIC para alguns casos; passe svgPublicSrc pelo PainelPanorama (feito no codigo).
PAINEL_BLOB_PUBLIC_FALLBACK=""

# Vercel Blob — token de leitura/escrita (apenas servidor). Usado no data-pipeline para upload
# e pelo Painel do blog para anexar imagens de capa/conteudo via /api/area-restrita/blog-upload.
# Vercel Dashboard: Storage → Blob store → Tokens → Read and Write.
BLOB_READ_WRITE_TOKEN=""

# Envio de e-mail (Resend) - LEGADO
# Hoje o fluxo principal e via WhatsApp. Estes campos so servem para o
# formulario antigo de contato. Pode ficar em branco.
RESEND_API_KEY=""
EMAIL_FROM=""

# Notificacoes workspace (fila de revisao, etc.)
ADMIN_NOTIFICATION_EMAIL=""

# Cron de saude dos dados (Vercel Cron -> /api/cron/data-health)
CRON_SECRET=""

# GitHub Actions status no dashboard /area-restrita/dados
GITHUB_TOKEN=""
GITHUB_REPOSITORY="owner/repo"

# Cole aqui o link do tipo https://chat.whatsapp.com/XXXXXXXXX gerado no WhatsApp.
# Quando vazio, o banner continua aparecendo mas o botao exibe "Link em breve".
NEXT_PUBLIC_WHATSAPP_COMMUNITY_URL=""
