// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String?
  passwordHash String
  role         String   @default("EDITOR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Author {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  name            String
  role            String
  headline        String?
  bio             String?
  photo           String?
  email           String?
  whatsapp        String?
  linkedin        String?
  instagram       String?
  experiencesJson String?
  educationJson   String?
  specialtiesJson String?
  posts           Post[]
  leads           AuthorLead[]
  whatsappClicks  AuthorWhatsappClick[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Post {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  excerpt    String?
  content    String
  category   String
  authorName String
  authorId   Int?
  author     Author?  @relation(fields: [authorId], references: [id])
  coverImage String?
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuthorLead {
  id          Int      @id @default(autoincrement())
  authorId    Int
  author      Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  message     String
  emailStatus String   @default("SKIPPED")
  createdAt   DateTime @default(now())
}

model AuthorWhatsappClick {
  id        Int      @id @default(autoincrement())
  authorId  Int
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  createdAt DateTime @default(now())
}

model FiiLead {
  id              Int      @id @default(autoincrement())
  name            String
  email           String
  aporteMensal    Float?
  patrimonio      Float?
  source          String   @default("PAINEL_FII")
  createdAt       DateTime @default(now())
}

model ConsorcioLead {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  tipoBem     String?
  objetivo    String?
  valorCarta  Float?
  prazoMeses  Int?
  parcela     Float?
  source      String   @default("SIMULADOR_CONSORCIO")
  createdAt   DateTime @default(now())
}
