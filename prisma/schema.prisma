// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  AUTHOR
  STAFF
}

enum PostStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model User {
  id                     Int       @id @default(autoincrement())
  email                  String    @unique
  name                   String?
  passwordHash           String
  role                   UserRole  @default(AUTHOR)
  active                 Boolean   @default(true)
  authorId               Int?      @unique
  author                 Author?   @relation(fields: [authorId], references: [id])
  inviteToken            String?   @unique
  inviteExpiresAt        DateTime?
  passwordResetToken     String?   @unique
  passwordResetExpiresAt DateTime?
  lastLoginAt            DateTime?
  reviewedPosts          Post[]    @relation("PostReviewedBy")
  auditLogs              AuditLog[]
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Author {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  name            String
  role            String
  headline        String?
  bio             String?
  photo           String?
  email           String?
  whatsapp        String?
  linkedin        String?
  instagram       String?
  experiencesJson String?
  educationJson   String?
  specialtiesJson String?
  posts           Post[]
  leads           AuthorLead[]
  whatsappClicks  AuthorWhatsappClick[]
  workspaceUser   User?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Post {
  id           Int        @id @default(autoincrement())
  title        String
  slug         String     @unique
  excerpt      String?
  content      String
  contentHtml  String?
  category     String
  authorName   String
  authorId     Int?
  author       Author?    @relation(fields: [authorId], references: [id])
  coverImage   String?
  status       PostStatus @default(DRAFT)
  published    Boolean    @default(false)
  submittedAt  DateTime?
  reviewedAt   DateTime?
  reviewedById Int?
  reviewedBy   User?      @relation("PostReviewedBy", fields: [reviewedById], references: [id])
  reviewNote   String?
  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  comments     PostComment[]
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  name      String
  content   String
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model AuthorLead {
  id          Int      @id @default(autoincrement())
  authorId    Int
  author      Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  name        String
  email       String
  phone       String?
  message     String
  emailStatus String   @default("SKIPPED")
  createdAt   DateTime @default(now())
}

model AuthorWhatsappClick {
  id        Int      @id @default(autoincrement())
  authorId  Int
  author    Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  createdAt DateTime @default(now())
}

model FiiLead {
  id           Int      @id @default(autoincrement())
  name         String
  email        String
  aporteMensal Float?
  patrimonio   Float?
  source       String   @default("PAINEL_FII")
  createdAt    DateTime @default(now())
}

model ConsorcioLead {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  tipoBem    String?
  objetivo   String?
  valorCarta Float?
  prazoMeses Int?
  parcela    Float?
  source     String   @default("SIMULADOR_CONSORCIO")
  createdAt  DateTime @default(now())
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  type      String
  path      String?
  referrer  String?
  authorId  Int?
  postId    Int?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([authorId, createdAt])
  @@index([postId, createdAt])
  @@index([path, createdAt])
}

model DataSourceSnapshot {
  id             Int       @id @default(autoincrement())
  key            String    @unique
  label          String
  freshness      String?
  generatedAt    DateTime?
  lastDataLabel  String?
  workflowName   String?
  workflowStatus String?
  workflowUrl    String?
  workflowRunAt  DateTime?
  error          String?
  checkedAt      DateTime  @default(now())
}

/// Anotação de CRM sobre leads existentes (AuthorWhatsappClick, FiiLead,
/// ConsorcioLead, AuthorLead). Tabela única e aditiva — evita alterar as 4
/// tabelas de captura e mantém a migration sem risco para produção.
model LeadStatus {
  id        Int      @id @default(autoincrement())
  leadTipo  String // "whatsapp" | "fii" | "consorcio" | "form"
  leadId    Int
  status    String   @default("novo") // novo | contactado | convertido | descartado
  nota      String?
  updatedBy Int?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([leadTipo, leadId])
  @@index([status])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  Int?
  meta      String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
}
